      "inputs": [
        { "id": "period", "name": "RSI Period", "type": "number", "required": true, "defaultValue": 14 },
        { "id": "threshold", "name": "Threshold", "type": "number", "required": true, "defaultValue": 60 },
        { "id": "direction", "name": "Direction", "type": "string", "required": true, "defaultValue": "above" }
      ],
      "outputs": [{ "id": "signal", "name": "Signal", "type": "signal" }],
      "config": {},
      "position": { "x": 100, "y": 280 }
    },
