        { "id": "quantity", "name": "Contracts", "type": "number", "required": true, "defaultValue": 1 }
      ],
      "outputs": [{ "id": "executed", "name": "Executed", "type": "signal" }],
      "config": { "option_type": "put", "strike_selection": "ATM", "expiration_days": 30, "leg": "long" },
