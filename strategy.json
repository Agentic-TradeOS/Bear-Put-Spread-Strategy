{
  "name": "Bear Put Spread",
  "description": "A defined-risk options strategy that profits from a moderate downward move. Buy a higher-strike put and sell a lower-strike put with the same expiration. Max loss is the net debit. Max profit is the spread width minus the debit.",
  "category": "options",
  "tags": ["options", "bear-put-spread", "defined-risk", "debit-spread", "vertical-spread", "bearish"],
  "asset_types": ["options"],
  "visibility": "public",
